# Runtime limits
B2B_MAX_FILE_MB=25
B2B_MAX_PAGES=50
B2B_MAX_INFLIGHT_MB=512
B2B_CONFIDENCE_THRESHOLD=0.90
B2B_ALLOW_UNSCANNED_DEV=false

# Generic IMAP source
B2B_IMAP_HOST=imap.example.com
B2B_IMAP_PORT=993
B2B_IMAP_USER=ap@example.com
B2B_IMAP_PASSWORD=change-me
B2B_IMAP_MAILBOX=INBOX
B2B_IMAP_SEARCH=UNSEEN

# Google Sheets ledger
B2B_GOOGLE_SHEET_ID=
B2B_GOOGLE_SERVICE_ACCOUNT_FILE=

# Desktop app stores OAuth tokens and API keys in Windows Credential Manager.
# These env vars remain for CLI/dev fallback only.

# ClamAV clamd. Keep this bound to localhost or a protected local socket.
B2B_CLAMAV_HOST=127.0.0.1
B2B_CLAMAV_PORT=3310
B2B_CLAMAV_TIMEOUT_SECONDS=15
